{
  "name": "@kansodata/openclaw-databricks-plugin",
  "version": "0.1.1",
  "description": "External Databricks read-only SQL plugin for OpenClaw.",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "index.ts",
    "runtime-api.ts",
    "openclaw.plugin.json",
    "README.md",
    "skills",
    "src"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "openclaw": "^2026.4.2",
    "oxlint": "^1.26.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@kansodata/openclaw-databricks-plugin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.28"
    }
  }
}
